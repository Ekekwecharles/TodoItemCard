{
  "name": "todoitemcard",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:ci": "concurrently -k -s first \"vite --port 5173 --strictPort\" \"wait-on tcp:127.0.0.1:5173 && cypress run\""
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/user-event": "^14.6.1",
    "cypress": "^14.0.0",
    "jsdom": "^26.0.0",
    "concurrently": "^9.1.2",
    "wait-on": "^8.0.1",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
